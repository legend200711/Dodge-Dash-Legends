# ============================================
# PlaylistSync – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to source control.
# ============================================

# ── App ──
PORT=3001
APP_URL=http://localhost:3001
ALLOWED_ORIGIN=http://localhost:3001

# ── Firebase (Client – used in firebase/config.js) ──
# Get these from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Admin SDK (Server-side) ──
# Generate from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── YouTube Data API v3 ──
# Enable at https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# ── Spotify ──
# Register at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Apple Music ──
# MusicKit setup: https://developer.apple.com/documentation/musickitjs
# Team token is a JWT signed with your MusicKit private key
APPLE_TEAM_TOKEN=
APPLE_KEY_ID=
APPLE_TEAM_ID=

# ── Amazon Music ──
# Register at https://developer.amazon.com/settings/console/registration
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=

# ── Napster ──
# Register at https://developer.napster.com/
NAPSTER_CLIENT_ID=
NAPSTER_CLIENT_SECRET=
